#!/bin/bash

# Claude Session Timer
# Waits until a specified time, then starts a claude session with minimal tokens

set -e

usage() {
    echo "Usage: claude-timer <time>"
    echo "  time: HH:MM (24-hour format) or 'now'"
    echo ""
    echo "Examples:"
    echo "  claude-timer 8:00   # Wait until 8:00am"
    echo "  claude-timer 14:30  # Wait until 2:30pm"
    echo "  claude-timer now    # Start immediately"
    exit 1
}

if [ -z "$1" ]; then
    usage
fi

TARGET="$1"

if [ "$TARGET" = "now" ]; then
    echo "Starting claude session now..."
    exec claude "."
fi

# Validate time format
if ! [[ "$TARGET" =~ ^[0-9]{1,2}:[0-9]{2}$ ]]; then
    echo "Error: Invalid time format. Use HH:MM (e.g., 8:00 or 14:30)"
    exit 1
fi

# Parse hours and minutes
HOUR="${TARGET%%:*}"
MINUTE="${TARGET##*:}"

# Validate ranges
if [ "$HOUR" -gt 23 ] || [ "$MINUTE" -gt 59 ]; then
    echo "Error: Invalid time. Hours must be 0-23, minutes must be 0-59"
    exit 1
fi

# Calculate target timestamp
TODAY=$(date +%Y-%m-%d)
TARGET_TIME=$(date -j -f "%Y-%m-%d %H:%M" "$TODAY $HOUR:$MINUTE" +%s 2>/dev/null)
NOW=$(date +%s)

# If target time has passed today, schedule for tomorrow
if [ "$TARGET_TIME" -le "$NOW" ]; then
    TOMORROW=$(date -v+1d +%Y-%m-%d)
    TARGET_TIME=$(date -j -f "%Y-%m-%d %H:%M" "$TOMORROW $HOUR:$MINUTE" +%s)
    echo "Time has passed today. Scheduling for tomorrow."
fi

DELAY=$((TARGET_TIME - NOW))
TARGET_DISPLAY=$(date -r "$TARGET_TIME" "+%Y-%m-%d %H:%M")

echo "Waiting until $TARGET_DISPLAY ($DELAY seconds)..."
echo "Press Ctrl-C to cancel."

sleep "$DELAY"

echo "Starting claude session..."
exec claude "."
